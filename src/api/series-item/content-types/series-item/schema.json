{
  "kind": "collectionType",
  "collectionName": "series_items",
  "info": {
    "singularName": "series-item",
    "pluralName": "series-items",
    "displayName": "Series"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
